DISCORD_BOT_TOKEN="op://<vault>/<item>/token"
DISCORD_CLIENT_ID="op://<vault>/<item>/client_id"
DISCORD_GUILD_ID="op://<vault>/<item>/guild_id"
MOCK_SYSTEM_ALERT_CHANNEL_ID="op://<vault>/<item>/system_alert_channel_id"
MOCK_ORCHESTRATOR_ENABLED=true
MOCK_ORCHESTRATOR_MONITOR_INTERVAL_SEC=15
MOCK_ORCHESTRATOR_FAILURE_THRESHOLD=3
MOCK_ORCHESTRATOR_COMMAND_TIMEOUT_SEC=240
MOCK_ORCHESTRATOR_COMPOSE_BUILD=true
MOCK_AGENT_STATUS_TIMEOUT_SEC=180
MOCK_AGENT_POLL_INTERVAL_MS=800
MOCK_AGENT_APPROVAL_RETRY_MAX=3
GATEWAY_API_HOST=0.0.0.0
GATEWAY_API_PORT=3800
GATEWAY_API_BASE_URL=http://127.0.0.1:3800
AGENT_RUNTIME_BASE_URL=http://127.0.0.1:3801
AGENT_RUNTIME_TIMEOUT_SEC=30
AGENT_GATEWAY_BASE_URL=http://host.docker.internal:3800
AGENT_MCP_TIMEOUT_SEC=30
AGENT_SDK_PROVIDER=mock
COPILOT_GITHUB_TOKEN="op://<vault>/<item>/copilot_github_token"
COPILOT_MODEL=claude-sonnet-4.6
COPILOT_WORKING_DIRECTORY=/Volumes/nekodisk/github/yui-ai
COPILOT_SEND_TIMEOUT_MS=180000
COPILOT_SDK_LOG_LEVEL=info
CONTAINER_SESSION_ROOT=/tmp/yui-ai/session
CONTAINER_CLI_TIMEOUT_SEC=60
HOST_CLI_TIMEOUT_SEC=60
HOST_HTTP_TIMEOUT_SEC=60
HOST_CLI_ALLOWLIST=git,node,npm,yarn,curl
SESSION_IDLE_TIMEOUT_SEC=600
POSTGRES_DB="op://<vault>/<item>/postgres_db"
POSTGRES_USER="op://<vault>/<item>/postgres_user"
POSTGRES_PASSWORD="op://<vault>/<item>/postgres_password"
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=55432
STATE_STORE_DSN="op://<vault>/<item>/state_store_dsn"
MEMORY_STORE_DSN="op://<vault>/<item>/memory_store_dsn"
TASK_EVENTS_RETENTION_DAYS=90
AUDIT_LOGS_RETENTION_DAYS=180
