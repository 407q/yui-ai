{
  "name": "yui-ai-discord-bot-mockup",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "yarn@1.22.22",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean:appledouble": "find . -depth -name '._*' -exec rm -rf {} +",
    "dev": "tsx apps/gateway/api/src/bot.ts",
    "dev:gateway:op": "op run --env-file=.env.op -- yarn dev",
    "start": "node dist/apps/gateway/api/bot.js",
    "register:commands": "tsx apps/gateway/api/src/registerCommands.ts",
    "register:commands:op": "op run --env-file=.env.op -- yarn register:commands",
    "db:migrate": "tsx apps/gateway/state/src/migrate.ts",
    "db:migrate:op": "op run --env-file=.env.op -- yarn db:migrate",
    "db:cleanup": "tsx apps/gateway/state/src/cleanup.ts",
    "db:cleanup:op": "op run --env-file=.env.op -- yarn db:cleanup",
    "db:smoke": "tsx apps/gateway/state/src/smoke.ts",
    "db:smoke:op": "op run --env-file=.env.op -- yarn db:smoke",
    "compose:up": "yarn clean:appledouble && op run --env-file=.env.op -- docker compose up -d",
    "compose:down": "yarn clean:appledouble && op run --env-file=.env.op -- docker compose down --remove-orphans",
    "compose:ps": "yarn clean:appledouble && op run --env-file=.env.op -- docker compose ps",
    "compose:logs": "yarn clean:appledouble && op run --env-file=.env.op -- docker compose logs -f --tail=100"
  },
  "dependencies": {
    "discord.js": "^14.18.0",
    "dotenv": "^16.4.7",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/pg": "^8.18.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
