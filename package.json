{
  "name": "yui-ai-discord-bot-mockup",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "yarn@1.22.22",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean:appledouble": "find . -depth -name '._*' -exec rm -rf {} +",
    "dev:local": "tsx apps/gateway/api/src/bot.ts",
    "dev": "op run --env-file=.env.op -- yarn dev:local",
    "start:local": "node dist/apps/gateway/api/bot.js",
    "start": "op run --env-file=.env.op -- yarn start:local",
    "register:commands:local": "tsx apps/gateway/api/src/registerCommands.ts",
    "register:commands": "op run --env-file=.env.op -- yarn register:commands:local",
    "db:migrate:local": "tsx apps/gateway/state/src/migrate.ts",
    "db:migrate": "op run --env-file=.env.op -- yarn db:migrate:local",
    "db:cleanup:local": "tsx apps/gateway/state/src/cleanup.ts",
    "db:cleanup": "op run --env-file=.env.op -- yarn db:cleanup:local",
    "db:smoke:local": "tsx apps/gateway/state/src/smoke.ts",
    "db:smoke": "op run --env-file=.env.op -- yarn db:smoke:local",
    "compose:up:local": "docker compose up -d",
    "compose:up": "yarn clean:appledouble && op run --env-file=.env.op -- yarn compose:up:local",
    "compose:down:local": "docker compose down --remove-orphans",
    "compose:down": "yarn clean:appledouble && op run --env-file=.env.op -- yarn compose:down:local",
    "compose:ps:local": "docker compose ps",
    "compose:ps": "yarn clean:appledouble && op run --env-file=.env.op -- yarn compose:ps:local",
    "compose:logs:local": "docker compose logs -f --tail=100",
    "compose:logs": "yarn clean:appledouble && op run --env-file=.env.op -- yarn compose:logs:local"
  },
  "dependencies": {
    "discord.js": "^14.18.0",
    "dotenv": "^16.4.7",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/pg": "^8.18.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
