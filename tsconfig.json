{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "rootDir": "apps/gateway/api/src",
    "outDir": "dist/apps/gateway/api",
    "noEmitOnError": true
  },
  "include": [
    "apps/gateway/api/src/**/*.ts"
  ]
}
