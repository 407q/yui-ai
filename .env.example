DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=
DISCORD_API_BASE_URL=https://discord.com/api/v10
BOT_MODE=standard
BOT_SYSTEM_ALERT_CHANNEL_ID=
BOT_IDLE_TIMEOUT_SEC=600
BOT_APPROVAL_TIMEOUT_SEC=120
BOT_ORCHESTRATOR_ENABLED=true
BOT_ORCHESTRATOR_MONITOR_INTERVAL_SEC=15
BOT_ORCHESTRATOR_FAILURE_THRESHOLD=3
BOT_ORCHESTRATOR_COMMAND_TIMEOUT_SEC=240
BOT_ORCHESTRATOR_CLEANUP_ENABLED=true
BOT_ORCHESTRATOR_CLEANUP_INTERVAL_SEC=86400
BOT_ORCHESTRATOR_COMPOSE_BUILD=true
# max seconds without agent task activity before bot polling treats it as timeout
BOT_AGENT_STATUS_TIMEOUT_SEC=180
BOT_AGENT_POLL_INTERVAL_MS=800
BOT_DELIVERED_FILE_MAX_BYTES=2097152
BOT_DELIVERED_FILE_MAX_COUNT=3
GATEWAY_API_HOST=127.0.0.1
GATEWAY_API_PORT=3800
GATEWAY_API_BASE_URL=http://127.0.0.1:3800
GATEWAY_API_SOCKET_PATH=/tmp/sockets/gateway-api.sock
AGENT_RUNTIME_BASE_URL=http://127.0.0.1:3801
AGENT_RUNTIME_SOCKET_PATH=/tmp/sockets/agent-runtime.sock
AGENT_SOCKET_PATH=/tmp/sockets/agent-runtime.sock
AGENT_GATEWAY_API_SOCKET_PATH=/tmp/sockets/gateway-api.sock
RUNTIME_SOCKET_DIR=/tmp/sockets
INTERNAL_CONNECTION_MODE=tcp
POSTGRES_SOCKET_DIR=/tmp/postgres-socket
POSTGRES_SOCKET_PATH=/tmp/postgres-socket
POSTGRES_SOCKET_PORT=5432
DB_SOCKET_MOUNT_PATH=/tmp/postgres-socket
AGENT_RUNTIME_TIMEOUT_SEC=30
AGENT_GATEWAY_BASE_URL=http://host.docker.internal:3800
AGENT_MCP_TIMEOUT_SEC=30
BOT_TO_GATEWAY_INTERNAL_TOKEN=
GATEWAY_TO_AGENT_INTERNAL_TOKEN=
AGENT_TO_GATEWAY_INTERNAL_TOKEN=
COPILOT_GITHUB_TOKEN=
COPILOT_MODEL=claude-sonnet-4.6
COPILOT_WORKING_DIRECTORY=/app
# wait budget from last tool execution activity to session.idle (ms)
COPILOT_SEND_TIMEOUT_MS=180000
COPILOT_SDK_LOG_LEVEL=info
CONTAINER_SESSION_ROOT=/agent/session
CONTAINER_CLI_TIMEOUT_SEC=60
CONTAINER_TOOL_EXECUTION_MODE=docker_exec
AGENT_CONTAINER_NAME=yui-ai-agent
CONTAINER_DOCKER_CLI_TIMEOUT_SEC=60
DOCKER_PROJECT_ROOT=.
HOST_CLI_TIMEOUT_SEC=60
HOST_HTTP_TIMEOUT_SEC=60
HOST_CLI_ALLOWLIST=git,node,npm,yarn,curl
HOST_CLI_ENV_ALLOWLIST=
MEMORY_NAMESPACE_VALIDATION_MODE=warn
SESSION_IDLE_TIMEOUT_SEC=600
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=55432
STATE_STORE_DSN=
MEMORY_STORE_DSN=
TASK_EVENTS_RETENTION_DAYS=90
AUDIT_LOGS_RETENTION_DAYS=180
